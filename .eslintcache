\r\nexport default () => {\r\n  const [source, setSource] = React.useState(\"\");\r\n  const [state, setState] = React.useState(\"init\");\r\n\r\n  const fetchMarkDown = React.useCallback((url: string) => {\r\n    fetchMd(url)\r\n      .then((text) => setSource(text))\r\n      .catch(() => setState(\"fail\"));\r\n  }, []);\r\n\r\n  return { state, source, fetchMarkDown };\r\n};\r\n","C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\styles\\GlobalStyle.ts",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\templates\\Wrapper.tsx",["55"],"import React from \"react\";\r\nimport styled from \"styled-components\";\r\n\r\nconst Wrapper = styled.div`\r\n  box-sizing: border-box;\r\n  margin: 0 auto;\r\n  width: 70%;\r\n  padding: 20px;\r\n`;\r\n\r\nexport default Wrapper;\r\n","C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\templates\\Header.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\templates\\Footer.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\pages\\ListPage.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\pages\\DetailPage.tsx",["56"],"import React from \"react\";\r\nimport { Link, useHistory, useParams } from \"react-router-dom\";\r\nimport MarkdownPreview from \"@uiw/react-markdown-preview\";\r\nimport fm from \"front-matter\";\r\nimport useMarkDown from \"../hooks/useMarkDown\";\r\n\r\nexport default function MarkDownPage() {\r\n  let { id } = useParams<{ id: string }>();\r\n  let history = useHistory();\r\n  const { state, source, fetchMarkDown } = useMarkDown();\r\n\r\n  React.useEffect(() => {\r\n    if (state == \"fail\") history.push(\"/error\");\r\n  }, [state, history]);\r\n\r\n  React.useEffect(() => {\r\n    fetchMarkDown(id);\r\n  }, [id, fetchMarkDown]);\r\n\r\n  return (\r\n    <>\r\n      <MarkdownPreview source={fm(source).body} />\r\n      <Link to={`/`}>list</Link>\r\n    </>\r\n  );\r\n}\r\n","C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\posts\\importUtil.ts",["57","58"],"\r\nconst importAll = (r: __WebpackModuleApi.RequireContext) => {\r\n    return r.keys().map((fileName: string) => {\r\n        return ({\r\n            name: fileName.substr(2).replace(/\\/index\\.mdx$/, ''),\r\n            title: fileName.replace(/\\/index\\.mdx$/, '').substring(13, fileName.indexOf('.post')),\r\n            staticUrl: r(fileName).default\r\n        })\r\n    })\r\n}\r\n\r\n// 전체 리스트\r\nconst list = importAll(require.context(\"./\", false, /\\.post$/)).reverse();\r\n\r\n// 페이징 리스트\r\nexport const fetchMdList = (offset: number, limit: number) => {\r\n    return list.slice(offset, limit)\r\n}\r\n\r\n// 디테일   \r\nexport const fetchMd = (id: string) => {\r\n    const result = list.filter((i) => i.name == id);\r\n    return new Promise<string>((resolve, reject) => {\r\n        if (result.length == 0) reject(\"not found\")\r\n        result.map((i) => fetch(i.staticUrl).then((resp) => resolve(resp.text())).catch(reject));\r\n    })\r\n}",["59","60"],{"ruleId":"61","replacedBy":"62"},{"ruleId":"63","replacedBy":"64"},{"ruleId":"65","severity":1,"message":"66","line":4,"column":1,"nodeType":"67","endLine":15,"endColumn":3},{"ruleId":"68","severity":1,"message":"69","line":1,"column":8,"nodeType":"70","messageId":"71","endLine":1,"endColumn":13},{"ruleId":"72","severity":1,"message":"73","line":13,"column":15,"nodeType":"74","messageId":"75","endLine":13,"endColumn":17},{"ruleId":"72","severity":1,"message":"73","line":22,"column":46,"nodeType":"74","messageId":"75","endLine":22,"endColumn":48},{"ruleId":"72","severity":1,"message":"73","line":24,"column":27,"nodeType":"74","messageId":"75","endLine":24,"endColumn":29},{"ruleId":"61","replacedBy":"76"},{"ruleId":"63","replacedBy":"77"},"no-native-reassign",["78"],"no-negated-in-lhs",["79"],"import/no-anonymous-de