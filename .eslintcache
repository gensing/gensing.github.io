tchMarkDown };\r\n};\r\n","C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\styles\\GlobalStyle.ts",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\pages\\ListPage.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\pages\\DetailPage.tsx",["74"],"import React from \"react\";\r\nimport { useHistory, useParams } from \"react-router-dom\";\r\nimport fm from \"front-matter\";\r\nimport useMarkDown from \"../hooks/useMarkDown\";\r\nimport Detail from \"../components/UI/contents/Detail\";\r\n\r\nexport default function MarkDownPage() {\r\n  let { id } = useParams<{ id: string }>();\r\n  let history = useHistory();\r\n  const { state, source, fetchMarkDown } = useMarkDown();\r\n\r\n  React.useEffect(() => {\r\n    if (state == \"fail\") history.push(\"/error\");\r\n  }, [state, history]);\r\n\r\n  React.useEffect(() => {\r\n    fetchMarkDown(id);\r\n  }, [id, fetchMarkDown]);\r\n\r\n  return <Detail source={fm(source).body} />;\r\n}\r\n","C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\posts\\importUtil.ts",["75","76"],"\r\nconst importAll = (r: __WebpackModuleApi.RequireContext) => {\r\n    return r.keys().map((fileName: string) => {\r\n        return ({\r\n            name: fileName.substr(2).replace(/\\/index\\.mdx$/, ''),\r\n            title: fileName.replace(/\\/index\\.mdx$/, '').substring(13, fileName.indexOf('.post')),\r\n            staticUrl: r(fileName).default\r\n        })\r\n    })\r\n}\r\n\r\n// 전체 리스트\r\nconst list = importAll(require.context(\"./\", false, /\\.post$/)).reverse();\r\n\r\n// 페이징 리스트\r\nexport const fetchMdList = (offset: number, limit: number) => {\r\n    return list.slice(offset, limit)\r\n}\r\n\r\n// 디테일   \r\nexport const fetchMd = (id: string) => {\r\n    const result = list.filter((i) => i.name == id);\r\n    return new Promise<string>((resolve, reject) => {\r\n        if (result.length == 0) reject(\"not found\")\r\n        result.map((i) => fetch(i.staticUrl, {\r\n            method: \"get\",\r\n            headers: {\r\n                Accept: \"application/octet-stream\",\r\n                \"Content-Type\": \"application/octet-stream\",\r\n            },\r\n        }).then((resp) => resolve(resp.text())).catch(reject));\r\n    })\r\n}","C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\templates\\atoms\\Wrapper.tsx",[],["77","78"],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\templates\\atoms\\Grid.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\templates\\atoms\\A.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\UI\\globals\\Header.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\UI\\globals\\Footer.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\UI\\contents\\List.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\UI\\contents\\Detail.tsx",[],"C:\\Users\\tensing\\tensing\\Dev\\coding\\service\\ts-React-gs-pages\\src\\components\\UI\\layouts\\MainLayout.tsx",[],{"ruleId":"79","replacedBy":"80"},{"ruleId":"81","replacedBy":"82"},{"ruleId":"83","severity":1,"message":"84","line":4,"column":1,"nodeType":"85","endLine":15,"endColumn":3},{"ruleId":"86","severity":1,"message":"87","line":13,"column":15,"nodeType":"88","messageId":"89","endLine":13,"endColumn":17},{"ruleId":"86","severity":1,"message":"87","line":22,"column":46,"nodeType":"88","messageId":"89","endLine":22,"endColumn":48},{"ruleId":"86","severity":1,"message":"87","line":24,"column":27,"nodeType":"88","messageId":"89","endLine":24,"endColumn":29},{"ruleId":"79","replacedBy":"90"},{"ruleId":"81","replacedBy":"91"},"no-native-reassign",["92"],"no-negated-in-lhs",["93"],"import/no-anonymous-default-e